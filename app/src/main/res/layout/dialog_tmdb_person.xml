<?xml version="1.0" encoding="utf-8"?>
<!-- TMDB 人物详情全屏页面 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F141A"
    android:defaultFocusHighlightEnabled="false"
    android:stateListAnimator="@null">

    <!-- 滚动内容 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:defaultFocusHighlightEnabled="false"
        android:descendantFocusability="afterDescendants"
        android:fillViewport="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:stateListAnimator="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 头部区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:background="#16202A"
                android:gravity="center_vertical">

                <!-- 头像 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="150dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:id="@+id/profile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1C2530"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null" />

                </androidx.cardview.widget.CardView>

                <!-- 右侧信息 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical">

                    <!-- 姓名 -->
                    <TextView
                        android:id="@+id/name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="陈都灵" />

                    <!-- 英文名 -->
                    <TextView
                        android:id="@+id/role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#999999"
                        android:textSize="15sp"
                        tools:text="Chu Zhao" />

                    <!-- 统计信息（作品数、平均分等） -->
                    <TextView
                        android:id="@+id/stats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="参演 54 部作品 · 平均 6.8 分"
                        tools:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

            <!-- 照片轮播 -->
            <LinearLayout
                android:id="@+id/photosSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="照片"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/photosRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clipToPadding="false"
                    android:descendantFocusability="afterDescendants" />

            </LinearLayout>

            <!-- 简介 -->
            <LinearLayout
                android:id="@+id/biographySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="简介"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/biography"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="24dp"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:maxLines="8"
                    android:ellipsize="end"
                    tools:text="演员简介..." />

            </LinearLayout>

            <!-- 作品筛选标签 -->
            <LinearLayout
                android:id="@+id/filterSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="参与作品"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/departmentChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    app:selectionRequired="true"
                    app:singleSelection="true" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/mediaChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    app:selectionRequired="true"
                    app:singleSelection="true" />

            </LinearLayout>

            <!-- 作品列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/worksRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_tmdb_person_work" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 关闭按钮 -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/closeBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="12dp"
        android:src="@drawable/ic_audio_close"
        android:tint="@android:color/white" />

</FrameLayout>
